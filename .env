CLIENT_NAME=wkt
CONTAINER_NAME=scalargis-server
IMAGE_NAME=registry.wkt.pt/wkt/scalargis-server:latest
PORT=15550
THREADS=12
CHANNEL_TIMEOUT=120
CONNECTION_LIMIT=200
URL_PREFIX=/scalargis
HOST_PORT=5000
APP_CONFIG_FILE=
HOST_DATA_DIR=./data #/var/scalargis/data
# ProxyFix: use TRUSTED_PROXY=* to trust any upstream proxy (safe behind Apache), or set to the
# exact Docker gateway IP for stricter control: docker network inspect <network> | grep Gateway
#TRUSTED_PROXY=*
#URL_SCHEME=https
